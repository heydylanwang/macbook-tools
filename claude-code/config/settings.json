{
  "permissions": {
    "allow": [
      "mcp__plugin_claude-mem_mcp-search__search",
      "mcp__plugin_claude-mem_mcp-search__get_observations",
      "mcp__plugin_claude-mem_mcp-search__smart_search",
      "mcp__plugin_claude-mem_mcp-search__smart_outline",
      "mcp__plugin_claude-mem_mcp-search__smart_unfold",
      "mcp__plugin_claude-mem_mcp-search__timeline",
      "Read(~/.claude)",
      "Read(~/.claude/**)",
      "Write(~/.claude/**)",
      "Delete(~/.claude/**)",
      "Glob(~/.claude/**)",
      "Grep(~/.claude/**)",
      "Bash(git:*)",
      "Bash(yazi:*)",
      "WebSearch",
      "WebFetch(domain:github.com)"
    ],
    "deny": [
      "Read(./package-lock.json)",
      "Read(./.DS_Store)"
    ],
    "additionalDirectories": [
      "__HOME__/.claude",
      "__HOME__/projects/macbook-tools"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'plugin_dir=$(ls -d \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\"/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | awk -F/ '\"'\"'{ print $(NF-1) \"\\t\" $(0) }'\"'\"' | sort -t. -k1,1n -k2,2n -k3,3n -k4,4n | tail -1 | cut -f2-); exec \"__HOME__/.bun/bin/bun\" --env-file /dev/null \"${plugin_dir}src/index.ts\"'"
  },
  "enabledPlugins": {
    "claude-mem@thedotmack": true,
    "claude-hud@claude-hud": true
  },
  "extraKnownMarketplaces": {
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    },
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "defaultMode": "acceptEdits",
  "preferredLanguage": "zh-CN",
  "model": "sonnet",
  "effortLevel": "medium"
}
